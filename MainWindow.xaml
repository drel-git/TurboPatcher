<Window x:Class="TurboPatcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Turbo Patcher"
        Width="604" Height="680"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="PatcherButton" TargetType="Button">
            <Setter Property="Background" Value="#CC10303a"/>
            <Setter Property="Foreground" Value="#FFe8dcc8"/>
            <Setter Property="BorderBrush" Value="#FF2a8ba0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#CC17515f"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#CC0a1a1f"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ConfigTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#990a1210"/>
            <Setter Property="Foreground" Value="#FFe8dcc8"/>
            <Setter Property="BorderBrush" Value="#FF2a8ba0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="#FFe8b84a"/>
            <Setter Property="SelectionBrush" Value="#FF2a8ba0"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="8" Margin="8">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="4" Opacity="0.8"/>
        </Border.Effect>
        <Border CornerRadius="8" ClipToBounds="True" Background="#F00a1418">
            <DockPanel LastChildFill="True">
                <!-- Title bar -->
                <Border DockPanel.Dock="Top" Background="#DD061014" Height="36"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <TextBlock Text="  Turbo Patcher" VerticalAlignment="Center"
                                   Foreground="#FFe8b84a" FontFamily="Segoe UI Semibold" FontSize="13"/>
                        <Button Content="✕" Width="36" Height="36" HorizontalAlignment="Right"
                                Style="{StaticResource PatcherButton}"
                                BorderThickness="0" Background="Transparent"
                                Click="CloseButton_Click"/>
                    </Grid>
                </Border>

                <!-- Header band -->
                <Border DockPanel.Dock="Top" Height="64" Background="#CC061014"
                        BorderBrush="#FF2a8ba0" BorderThickness="0,0,0,1">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="TURBO SUITE" HorizontalAlignment="Center"
                                   Foreground="#FFe8dcc8" FontFamily="Segoe UI Black" FontSize="22"/>
                        <TextBlock Text="Installer / Updater" HorizontalAlignment="Center"
                                   Foreground="#FF6fa8b8" FontFamily="Segoe UI" FontSize="11"/>
                    </StackPanel>
                </Border>

                <!-- Bottom version -->
                <Grid DockPanel.Dock="Bottom" Margin="8,0,8,6">
                    <TextBlock x:Name="VersionText" HorizontalAlignment="Right" VerticalAlignment="Center"
                               Foreground="#FF706050" FontFamily="Segoe UI" FontSize="10"/>
                </Grid>

                <!-- Content -->
                <DockPanel Margin="20,14,20,44" LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="MacroQuest Folder" Foreground="#FFe8b84a"
                                   FontFamily="Segoe UI" FontSize="11" Margin="0,0,0,4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="MqDirTextBox" Grid.Column="0"
                                     Style="{StaticResource ConfigTextBox}"
                                     TextChanged="MqDirTextBox_TextChanged"/>
                            <Button Grid.Column="2" Content="Browse..." Width="72"
                                    Style="{StaticResource PatcherButton}"
                                    Click="BrowseButton_Click"/>
                        </Grid>

                        <TextBlock x:Name="StatusLine" Margin="0,8,0,0"
                                   Foreground="#FF9fb8c0" FontFamily="Segoe UI" FontSize="11"
                                   Text="Select your MacroQuest folder to begin."/>

                        <TextBlock Text="What's New" Foreground="#FFe8b84a"
                                   FontFamily="Segoe UI Semibold" FontSize="11" Margin="0,12,0,4"/>
                        <Border Height="200" Background="#88060e0a" BorderBrush="#FF2a8ba0"
                                BorderThickness="1" CornerRadius="3" Margin="0,0,0,10">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled" Padding="8,6">
                                <TextBlock x:Name="PatchNotesText"
                                           Foreground="#FFe8dcc8" FontFamily="Consolas" FontSize="11"
                                           TextWrapping="Wrap" LineHeight="18"
                                           Text="No patch notes available."/>
                            </ScrollViewer>
                        </Border>

                        <Button x:Name="ActionButton" Content="Check for Updates"
                                Style="{StaticResource PatcherButton}"
                                HorizontalAlignment="Stretch" Height="36"
                                Click="ActionButton_Click"/>

                        <Separator Background="#442a8ba0" Margin="0,12,0,12"/>
                    </StackPanel>

                    <TextBlock DockPanel.Dock="Top" Text="Log" Foreground="#FFe8b84a"
                               FontFamily="Segoe UI Semibold" FontSize="11" Margin="0,0,0,4"/>
                    <Border Background="#88060e0a" BorderBrush="#FF2a8ba0" BorderThickness="1" CornerRadius="3">
                        <ScrollViewer x:Name="LogScroller"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled" Padding="8,6">
                            <ItemsControl x:Name="LogItems">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="#FFe8dcc8"
                                                   FontFamily="Consolas" FontSize="11"
                                                   TextWrapping="Wrap" Margin="0,1"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </DockPanel>
            </DockPanel>
        </Border>
    </Border>
</Window>
