<Window x:Class="TurboPatcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Turbo Patcher"
        Icon="Assets/Turbo.ico"
        Width="604"
        Height="680"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <Style x:Key="PatcherButton"
               TargetType="Button">

            <Setter Property="Background"
                    Value="#CC10303a"/>

            <Setter Property="Foreground"
                    Value="#FFe8dcc8"/>

            <Setter Property="BorderBrush"
                    Value="#FF2a8ba0"/>

            <Setter Property="BorderThickness"
                    Value="1"/>

            <Setter Property="Padding"
                    Value="12,6"/>

            <Setter Property="FontFamily"
                    Value="Segoe UI"/>

            <Setter Property="FontSize"
                    Value="13"/>

            <Setter Property="Cursor"
                    Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">

                                <Setter Property="Background"
                                        Value="#CC17515f"/>

                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">

                                <Setter Property="Background"
                                        Value="#CC0a1a1f"/>

                            </Trigger>

                            <Trigger Property="IsEnabled"
                                     Value="False">

                                <Setter Property="Opacity"
                                        Value="0.35"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>

        </Style>

        <Style x:Key="ConfigTextBox"
               TargetType="TextBox">

            <Setter Property="Background"
                    Value="#990a1210"/>

            <Setter Property="Foreground"
                    Value="#FFe8dcc8"/>

            <Setter Property="BorderBrush"
                    Value="#FF2a8ba0"/>

            <Setter Property="BorderThickness"
                    Value="1"/>

            <Setter Property="Padding"
                    Value="4,3"/>

            <Setter Property="FontFamily"
                    Value="Segoe UI"/>

            <Setter Property="FontSize"
                    Value="12"/>

            <Setter Property="CaretBrush"
                    Value="#FFe8b84a"/>

            <Setter Property="SelectionBrush"
                    Value="#FF2a8ba0"/>

        </Style>

    </Window.Resources>

    <Border Margin="8"
            CornerRadius="8"
            BorderBrush="#FFD49A2A"
            BorderThickness="1">

        <Border.Effect>

            <DropShadowEffect Color="Black"
                              BlurRadius="20"
                              ShadowDepth="4"
                              Opacity="0.8"/>

        </Border.Effect>

        <Border Background="#F00a1418"
                CornerRadius="7"
                ClipToBounds="True">

            <DockPanel LastChildFill="True">

                <!-- Title bar -->
                <Border DockPanel.Dock="Top"
                        Height="36"
                        Background="#DD061014"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                    <Grid>

                        <TextBlock Text="  Turbo Patcher"
                                   VerticalAlignment="Center"
                                   Foreground="#FFe8b84a"
                                   FontFamily="Segoe UI Semibold"
                                   FontSize="13"/>

                        <Button Content="✕"
                                Width="36"
                                Height="36"
                                HorizontalAlignment="Right"
                                Style="{StaticResource PatcherButton}"
                                BorderThickness="0"
                                Background="Transparent"
                                Click="CloseButton_Click"/>

                    </Grid>

                </Border>

                <!-- Turbo Suite header -->
                <Border DockPanel.Dock="Top"
                        Height="68"
                        Margin="10,2,10,2"
                        Padding="10,2"
                        Background="#FF061014">

                    <Grid VerticalAlignment="Center">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="TURBO SUITE"
                                   HorizontalAlignment="Center"
                                   Foreground="#FF62F264"
                                   FontFamily="Consolas"
                                   FontWeight="Bold"
                                   FontSize="30">

                            <TextBlock.Effect>

                                <DropShadowEffect Color="#FF32FF39"
                                                  BlurRadius="6"
                                                  ShadowDepth="0"
                                                  Opacity="0.42"/>

                            </TextBlock.Effect>

                        </TextBlock>

                        <StackPanel Grid.Row="1"
                                    Margin="0,-2,0,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">

                            <Border Width="64"
                                    Height="1"
                                    Margin="0,8,12,0"
                                    Background="#FFD49A2A"/>

                            <TextBlock Text="INSTALLER / UPDATER"
                                       Foreground="#FFFFC24A"
                                       FontFamily="Consolas"
                                       FontWeight="Bold"
                                       FontSize="11"/>

                            <Border Width="64"
                                    Height="1"
                                    Margin="12,8,0,0"
                                    Background="#FFD49A2A"/>

                        </StackPanel>

                    </Grid>

                </Border>

                <!-- Bottom link and version -->
                <Grid DockPanel.Dock="Bottom"
                      Margin="12,0,8,6">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               FontFamily="Segoe UI"
                               FontSize="10">

                        <Hyperlink NavigateUri="https://github.com/drel-git/Turbo"
                                   RequestNavigate="FooterLink_RequestNavigate"
                                   Foreground="#FFD49A2A"
                                   TextDecorations="None">

                            Turbo on GitHub

                        </Hyperlink>

                    </TextBlock>

                    <TextBlock x:Name="VersionText"
                               Grid.Column="1"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Foreground="#FF706050"
                               FontFamily="Segoe UI"
                               FontSize="10"/>

                </Grid>

                <!-- Main content -->
                <DockPanel Margin="20,6,20,44"
                           LastChildFill="True">

                    <StackPanel DockPanel.Dock="Top">

                        <!-- Shown when this exe is behind GitHub latest release -->
                        <Border x:Name="SelfUpdateBanner"
                                Visibility="Collapsed"
                                Background="#332a1800"
                                BorderBrush="#FFD49A2A"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="10,8"
                                Margin="0,0,0,10">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock x:Name="SelfUpdateText"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Foreground="#FFFFC24A"
                                           FontFamily="Segoe UI"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Margin="0,0,10,0"
                                           Text="A newer Turbo Patcher is available."/>

                                <Button x:Name="SelfUpdateButton"
                                        Grid.Column="1"
                                        Content="Update Patcher"
                                        MinWidth="110"
                                        Style="{StaticResource PatcherButton}"
                                        BorderBrush="#FFD49A2A"
                                        Click="SelfUpdateButton_Click"/>

                            </Grid>

                        </Border>

                        <TextBlock Text="MacroQuest Folder"
                                   Foreground="#FFe8b84a"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   Margin="0,0,0,4"/>

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="MqDirTextBox"
                                     Grid.Column="0"
                                     Style="{StaticResource ConfigTextBox}"
                                     TextChanged="MqDirTextBox_TextChanged"/>

                            <Button Grid.Column="2"
                                    Content="Browse..."
                                    Width="72"
                                    Style="{StaticResource PatcherButton}"
                                    Click="BrowseButton_Click"/>

                        </Grid>

                        <TextBlock x:Name="StatusLine"
                                   Margin="0,8,0,0"
                                   Foreground="#FF9fb8c0"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Text="Select your MacroQuest folder to begin."/>

                        <TextBlock Text="What's New"
                                   Foreground="#FFe8b84a"
                                   FontFamily="Segoe UI Semibold"
                                   FontSize="11"
                                   Margin="0,12,0,4"/>

                        <Border Height="160"
                                Background="#88060e0a"
                                BorderBrush="#FF2a8ba0"
                                BorderThickness="1"
                                CornerRadius="3"
                                Margin="0,0,0,8">

                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Padding="8,6">

                                <TextBlock x:Name="PatchNotesText"
                                           Foreground="#FFe8dcc8"
                                           FontFamily="Consolas"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           LineHeight="18"
                                           Text="No patch notes available."/>

                            </ScrollViewer>

                        </Border>

                    </StackPanel>

                    <!-- Always pinned above the log so Update Now cannot scroll/clip away -->
                    <StackPanel DockPanel.Dock="Bottom"
                                Margin="0,0,0,8">

                        <Button x:Name="ActionButton"
                                Content="Check for Updates"
                                Style="{StaticResource PatcherButton}"
                                BorderBrush="#FFD49A2A"
                                Foreground="#FFE8DCC8"
                                Background="#CC1a4a38"
                                HorizontalAlignment="Stretch"
                                Height="40"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Click="ActionButton_Click"/>

                        <TextBlock x:Name="ActionHint"
                                   Margin="0,6,0,0"
                                   Foreground="#FF7a8a90"
                                   FontFamily="Segoe UI"
                                   FontSize="10"
                                   TextWrapping="Wrap"
                                   Text=""/>

                    </StackPanel>

                    <TextBlock DockPanel.Dock="Top"
                               Text="Log"
                               Foreground="#FFe8b84a"
                               FontFamily="Segoe UI Semibold"
                               FontSize="11"
                               Margin="0,0,0,4"/>

                    <Border Background="#88060e0a"
                            BorderBrush="#FF2a8ba0"
                            BorderThickness="1"
                            CornerRadius="3">

                        <ScrollViewer x:Name="LogScroller"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="8,6">

                            <ItemsControl x:Name="LogItems">

                                <ItemsControl.ItemTemplate>

                                    <DataTemplate>

                                        <TextBlock Text="{Binding}"
                                                   Foreground="#FFe8dcc8"
                                                   FontFamily="Consolas"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Margin="0,1"/>

                                    </DataTemplate>

                                </ItemsControl.ItemTemplate>

                            </ItemsControl>

                        </ScrollViewer>

                    </Border>

                </DockPanel>

            </DockPanel>

        </Border>

    </Border>

</Window>